    <script type="text/javascript">
function onCampainModalClick(campaignId, campaignName) 
{
    var dataLayer = window.dataLayer || [];
  dataLayer.push({ ecommerce: null });    dataLayer.push({
    'event': 'promotionClick',
    'ecommerce': {
      'promoClick': {
        'promotions': [{
          'id': campaignId,
          'name': campaignName,
        }]
      }
    },
  });
  dataLayer.push({ ecommerce: null }); 
    dataLayer.push({ ecommerce: null });    dataLayer.push({
    'event': 'select_promotion',
    'ecommerce': {
      'promotion_id': campaignId,
      'promotion_name': campaignName,
    },
  });
  dataLayer.push({ ecommerce: null }); 
  localStorage.setItem('promotion id', campaignId);
  localStorage.setItem('promotion name', campaignName);
}

function uaCampainModalView(bannerId, bannerName, index) 
{
    if (index === -1) return;

    var dataLayer = window.dataLayer || [];
  dataLayer.push({ ecommerce: null });    dataLayer.push({
    'event': 'promoView',
    'ecommerce': {
      'promoView': {
        'promotions': [{
          'id': bannerId,
          'name': bannerName,
        }]
      }
    },
  });
  dataLayer.push({ ecommerce: null }); }

function ga4CampainModalView(bannerId, bannerName, index) 
{
    if (index === -1) return;

    var dataLayer = window.dataLayer || [];
  dataLayer.push({ ecommerce: null });    dataLayer.push({
    'event': 'view_promotion',
    'ecommerce': {
      'promotion_id': bannerId,
      'promotion_name': bannerName,
    },
  });
  dataLayer.push({ ecommerce: null }); }
</script>

