    var dataLayer = window.dataLayer || [];
  dataLayer.push({ ecommerce: null });    dataLayer.push({
    'event': 'view_promotion',
    'ecommerce': {
      'promotion_id': bannerId,
      'promotion_name': bannerName,
    },
  });
  dataLayer.push({ ecommerce: null }); }
</script>
