  cartInEventPropartyObject = {
    "levelOneCategory": levelOneCategory,
    "levelTwoCategory": levelTwoCategory,
    "levelThreeCategory": levelThreeCategory,
    "serviceTypeId": serviceTypeId,
    'genderId': genderId
  }

  function addCartInEvent() {
    window.braze.logCustomEvent('cartInEvent', cartInEventPropartyObject);
  };
</script>
  <script src="https://cdn.buyee.jp/zozo/js/modal.js"></script>
  <script>
  var imageUrl = '';
  var headerBanner = [];
  var deviceType = '1';
  var startTime = new Date().getTime();
  var intervalTime = 1000;
  var timeout = 5000;
  var headerBannerContentCard = [];
  var headerBannerId = '5';

  $(window).on('load', function() {
    getHeaderBanner();
  });


  $(document).on({
    "mouseenter": function() {
      $(".braze-header-banner").css({
      "opacity": "0.8"
    })},
    "mouseleave": function() {
      $(".braze-header-banner").css({
      "opacity": "1"
    })}
  }, ".braze-header-banner");

    async function getHeaderBanner()
  {
    await requestHeaderContentCards()
      .then(() => {
                cards = braze.getCachedContentCards();
        if (cards.cards.length > 0) {
                    cards.cards.forEach(function(card){
            if(card.extras.sliderBannerTypeId === "3" && card.extras.deviceType === deviceType){
              headerBanner.push(card);
              headerBanner.sort(function(a, b){
                return a.extras.displayOrder - b.extras.displayOrder;
              });
            }
          });

                    if (headerBanner.length > 0) { 
            headerBanner.some(function(header){
              if (isHeaderDisplayPage(header.extras.displayPage)) {
                $(".header-banner").empty();
                $(".header-banner").css("display", "block");
                $(".header-banner").addClass('braze-header-banner');
                braze.logContentCardImpressions([header]);
                headerBannerContentCard[0] = header;
                displayHeaderBanner(header);
                return true;
              }
            });
          }
        } else {
                    reloadheaderContentCard();
        }
      })
  }

    function requestHeaderContentCards()
  {
    return new Promise((resolve, reject) => {
      braze.requestContentCardsRefresh();
      resolve();
    });
  }

    async function reloadheaderContentCard() 
  {
    await new Promise(s => setTimeout(s, intervalTime))
    var endTime = new Date().getTime();
    if (endTime - startTime > timeout) {
      return;
    }
    getHeaderBanner();
  }

    function isHeaderDisplayPage(displayPage) {
    var displayPageArray = displayPage.split(',');
    var isDisplay = false;
    displayPageArray.forEach(function(page){
      if (headerBannerId == page) {
        isDisplay = true;
      }
    });
    return isDisplay;
  }

    function displayHeaderBanner(headerBanner) {
    $(".braze-header-banner").css({
      "height": "50px",
      "background-color": "Transparent"
    });
    var appendHtml = `
      <a class='braze-header-banner-a' style="
      height: 50px;
      background-image: url(${headerBanner.imageUrl});
      background-size: 1200px 50px;
      margin-left: auto;
      margin-right: auto;
      background-color: ${headerBanner.extras.color};" 
      onclick='headerContentCardClick(event)'
      data-index="0" ></a>
    `;
    $(".header-banner").append(appendHtml);
  }

  function headerContentCardClick(event) {
    var index = event.currentTarget.getAttribute('data-index');
    var card = headerBannerContentCard[index];
    braze.logContentCardClick(card);
    window.location.href = card.url;
  }
  
</script>
