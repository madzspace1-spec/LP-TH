<script>
  const categoryLevel = '3';
  var cards = [];
  var categoryIds = [];
      categoryIds = ["101","2192"];
    var filterCards = [];
  var categoryTreeArary = [];
  var preUrl = document.referrer;
  var pageServiceTypeId = '13';

  $(window).on('load',function(){
    braze.requestContentCardsRefresh();
    getCards();
  });
  $('.brazeButton').on('click', function() {
        categoryContentCards(categoryIds, cards);
      })

  async function getCards() {
    await new Promise(s => setTimeout(s, 3000))
        cards = braze.getCachedContentCards();
    filterCards = braze.getCachedContentCards();

        if (categoryIds.length !== 0) {
      filterCards = [];
      categoryIds.forEach((categoryId) => {

                if ('string' !== typeof categoryId) {
          categoryId = categoryId.toString();
        }

                if (categoryId.trim() !== '' && cards.length !== 0) {
          cards.cards.forEach((card) => {
                        if (!card.extras.sliderBannerTypeId) {
              categoryTreeArary = [];
              categoryTreeString = card.extras.categoryTree;

                            if (categoryTreeString) {
                categoryTreeArary = categoryTreeString.split(',');
              }

                            if (isCategroryFilter(categoryIds, categoryTreeArary)) {
                categoryTreeArary.forEach((categoryTree) => {
                                    if (categoryTree === categoryId) {
                    filterCards.push(card);
                    filterCards = [...new Set(filterCards)];
                  }
                });
              }
            }
          });
          return;
        }
      });

            if (filterCards.length !== 0) {
        displayContentCards(cards, filterCards);
      }
    }

        displayContentCards(cards, filterCards);
  }

  function displayContentCards(cards, filterCards) {
    if (cards.cards.length !== 0 && filterCards.length !== 0) {
      cards.cards.forEach((card) => {
                if (!card.extras.sliderBannerTypeId && isDisplayByServiceTypeId(card.extras.serviceTypeId, pageServiceTypeId)) {
          return $('.brazeButton').css('display', 'block');
        }
      })
    }
  }

  function categoryContentCards(categoryIds, cards) {
    var categoryCards = [];

        if (categoryIds.length !== 0) {
      braze.toggleContentCards(null, function(filterCards) {
        categoryIds.forEach((categoryId) => {

                    if ('string' !== typeof categoryId) {
            categoryId = categoryId.toString();
          }

                    if (categoryId.trim() !== '' && cards.length !== 0) {
            cards.cards.forEach((card) => {
              categoryTreeArary = [];
              categoryTreeString = card.extras.categoryTree;

                            if (categoryTreeString) {
                categoryTreeArary = categoryTreeString.split(',');
              }

              if (isCategroryFilter(categoryIds, categoryTreeArary)) {
                                categoryTreeArary.forEach((categoryTree) => {

                                    if (categoryTree === categoryId) {
                    categoryCards.push(card);
                    categoryCards = [...new Set(categoryCards)];
                  }
                });
              }
            });
          }
        });
        return categoryCards;
      });
    } else {
            braze.toggleContentCards(null, function(cards) {
        cards.forEach((card) => {
                    if (!card.extras.sliderBannerTypeId && isDisplayByServiceTypeId(card.extras.serviceTypeId, pageServiceTypeId)) {
            categoryCards.push(card);
            categoryCards = [...new Set(categoryCards)];
          }
        })
        return categoryCards;
      });
    }
  }

    function isCategroryFilter (categoryIds, categoryTreeArary) {
    var isFlag = false;
    for (var index = 0; index < categoryLevel; index++) {
      if (categoryTreeArary[index] === undefined || categoryIds[index] === undefined) {         return isFlag = true;
      } else if (categoryIds[index] === categoryTreeArary[index]) {         if (categoryIds.length === index + 1 || categoryTreeArary.length === index + 1) {
          return isFlag = true;
        } else {
          continue;
        }
      } else {
        return isFlag = false;
      }
    }

    return isFlag;
  }

    function isDisplayByServiceTypeId (serviceTypeId, pageServiceTypeId) {
        if (serviceTypeId === undefined) {
      return true;
    }
        return serviceTypeId == pageServiceTypeId ? true : false;
  }

</script>
<script>
  var levelOneCategory = '101';
  var levelTwoCategory = '2192';
