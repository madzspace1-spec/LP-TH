    pushGa4DataViewProductDetails(itemData);

    // GA: event add to cart
    function handleGaAddToCartEvent()
    {
      // Universal Analytics (UA)
      var dataLayer = window.dataLayer || [];
      var gaData = {"productDetail":{"showDetail":{"items":[{"name":"\u30a2\u30c7\u30a3\u30ab\u30e9\u30fc \u30c7\u30cb\u30e0 \u30d5\u30a1\u30a4\u30e4\u30fc\u30d0\u30fc\u30c9 \u30c8\u30e9\u30c3\u30af\u30c8\u30c3\u30d7 \/ \u30b8\u30e3\u30fc\u30b8 \/ \u30c8\u30e9\u30c3\u30af\u30b8\u30e3\u30b1\u30c3\u30c8 \/ \u30a2\u30c7\u30a3\u30c0\u30b9\u30aa\u30ea\u30b8\u30ca\u30eb\u30b9 adidas Originals","id":"100516764","price":17600,"affiliation":"สล็อต888","dimension1":null,"dimension2":null,"dimension4":"shopping","dimension7":"สล็อต888"}]}},"listNames":{"category":"ZOZO Detail Recommend Category","brand":"ZOZO Detail Recommend Brand"}};
      gaData['productDetail']['showDetail']['items'][0]['quantity'] = document.getElementsByClassName('num')[0].value;
      dataLayer.push({ ecommerce: null }); // Clear the previous ecommerce object.
      dataLayer.push({
        'event': 'addToCart',
        'ecommerce': {
          'currencyCode': 'JPY',
          'add': {
            'products': gaData['productDetail']['showDetail']['items']
          }
        }
      });
      dataLayer.push({ ecommerce: null }); // Clear the ecommerce object after add to cart event.

      // GA4
      var ga4Data = {"productDetail":{"showDetail":{"items":[{"item_name":"\u30a2\u30c7\u30a3\u30ab\u30e9\u30fc \u30c7\u30cb\u30e0 \u30d5\u30a1\u30a4\u30e4\u30fc\u30d0\u30fc\u30c9 \u30c8\u30e9\u30c3\u30af\u30c8\u30c3\u30d7 \/ \u30b8\u30e3\u30fc\u30b8 \/ \u30c8\u30e9\u30c3\u30af\u30b8\u30e3\u30b1\u30c3\u30c8 \/ \u30a2\u30c7\u30a3\u30c0\u30b9\u30aa\u30ea\u30b8\u30ca\u30eb\u30b9 adidas Originals","item_id":"100516764","price":17600,"affiliation":"สล็อต888","dimension1":null,"dimension2":null,"dimension4":"shopping","dimension7":"สล็อต888"}]}},"listNames":{"category":"ZOZO Detail Recommend Category","brand":"ZOZO Detail Recommend Brand"}};
      var items = ga4Data['productDetail']['showDetail']['items'];
      items[0]['quantity'] = document.getElementsByClassName('num')[0].value;
      var revenue = parseInt(items[0]['price']) * parseInt(items[0]['quantity']);
      dataLayer.push({ ecommerce: null }); // Clear the previous ecommerce object.
      dataLayer.push({
        'event': 'add_to_cart',
        'ecommerce': {
          'currency': 'JPY',
          'value': revenue,
          'items': items
        }
      });
      dataLayer.push({ ecommerce: null }); // Clear the ecommerce object after add to cart event.
      addCartInEvent();
    }

    // Product click event for recommend list of item details page
    function handleGaProductClickRecommendList(id, name, price, index, partnerSellerId)
    {
      // Empty GA index
      if (index === -1) {
        return;
      }

      if (partnerSellerId === '802') {
        partnerSellerId = 'SLOT888';
      } else {
        partnerSellerId = 'สล็อต888';
      }

      var campaignUrlParams = {"rc":null,"vic":null};
      var item = {
        'id': id,
        'name': name,
        'price': price,
        'quantity': 1,
        'affiliation': 'สล็อต888',
        'dimension1': campaignUrlParams.rc,
        'dimension2': campaignUrlParams.vic,
        'dimension4': 'shopping',
        'partnerSellerId': partnerSellerId,
        'position': index + 1,
        'currencyCode': 'JPY',
        'list': 'Z item recommend list link'
      }

      // Push dataLayer product click
      pushDataLayerProductClick(item);
    }
  </script>
    

